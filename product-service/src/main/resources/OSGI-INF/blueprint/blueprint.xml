<?xml version="1.0" encoding="UTF-8"?>
<blueprint xmlns="http://www.osgi.org/xmlns/blueprint/v1.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:jaxrs="http://cxf.apache.org/blueprint/jaxrs"
    xmlns:cm="http://aries.apache.org/blueprint/xmlns/blueprint-cm/v1.1.0"
    xsi:schemaLocation="http://www.osgi.org/xmlns/blueprint/v1.0.0 http://www.osgi.org/xmlns/blueprint/v1.0.0/blueprint.xsd
                        http://cxf.apache.org/blueprint/jaxrs http://cxf.apache.org/schemas/blueprint/jaxrs.xsd
                        http://aries.apache.org/blueprint/xmlns/blueprint-cm/v1.1.0 http://aries.apache.org/schemas/blueprint-cm/blueprint-cm-1.1.0.xsd">
    <reference id="dataSource"
        interface="javax.sql.DataSource"
        filter="(dataSourceName=productDS)" />

    <bean id="jsonProvider" class="com.fasterxml.jackson.jaxrs.json.JacksonJsonProvider" />

    <bean id="healthResource" class="com.dthvinh.rs.HealthResource" />

    <bean id="productResource" class="com.dthvinh.rs.ProductResource" depends-on="storage">
        <argument ref="storage" />
    </bean>

    <bean id="storage" class="com.dthvinh.service.storage.impl.ProductStorageImpl"
        init-method="init">
        <argument ref="dataSource" />
    </bean>

    <jaxrs:server id="productServiceApi" address="/api">
        <jaxrs:serviceBeans>
            <ref component-id="healthResource" />
            <ref component-id="productResource" />
        </jaxrs:serviceBeans>

        <jaxrs:providers>
            <ref component-id="jsonProvider" />
        </jaxrs:providers>
    </jaxrs:server>

</blueprint>
<?xml version="1.0" encoding="UTF-8"?>
<features xmlns="http://karaf.apache.org/xmlns/features/v1.4.0" name="inventory-service">
    <repository>
        mvn:org.apache.karaf.features/standard/4.4.6/xml/features
    </repository>

    <repository>
        mvn:org.apache.cxf.karaf/apache-cxf/3.5.6/xml/features
    </repository>

    <feature name="inventory-service-api" version="${project.version}">
        <feature>cxf-jaxrs</feature>
        <feature>aries-blueprint</feature>
        <feature>cxf-jackson</feature>

        <feature>pax-jdbc</feature>
        <feature>pax-jdbc-config</feature>
        <feature>pax-jdbc-pool-dbcp2</feature>

        <bundle>mvn:${project.groupId}/common/${project.version}</bundle>
        <bundle>mvn:${project.groupId}/${project.artifactId}/${project.version}</bundle>

        <bundle>mvn:com.google.code.gson/gson/2.13.2</bundle>
        <bundle>mvn:com.fasterxml.jackson.core/jackson-annotations/2.21</bundle>

        <bundle>mvn:org.apache.commons/commons-pool2/2.12.0</bundle>
        <bundle>mvn:org.json/json/20231013</bundle>
        <bundle>wrap:mvn:redis.clients/jedis/5.1.2</bundle>

        <bundle>wrap:mvn:org.postgresql/postgresql/42.7.10</bundle>
    </feature>
</features>